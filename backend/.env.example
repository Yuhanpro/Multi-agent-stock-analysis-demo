# Required — get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxx

# DeepSeek API base. Use the OpenAI-compatible endpoint.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional — daily total budget for LLM cost (USD). Defaults to 10.
DAILY_BUDGET_USD=10

# Optional — per-IP rate limits (requests/hour). Defaults shown.
RATE_LIMIT_QUICK=5/hour
RATE_LIMIT_DEBATE=1/hour

# Redis (Railway plugin sets REDIS_URL automatically; "memory" = no Redis)
REDIS_URL=memory

# CORS allowlist (comma-separated). Default: localhost:3000 only.
CORS_ORIGINS=http://localhost:3000

# DeepSeek model ids (DeepSeek V4 generation, June 2026):
#   deepseek-v4-flash   ~$0.14/$0.55 per 1M (input/output)  ← quick path, TA internal calls
#   deepseek-v4-pro     ~$0.435/$1.65 per 1M               ← TA debate deep_think
#   deepseek-chat       (legacy alias for v4-flash non-think; deprecated 2026-07-24)
#   deepseek-reasoner   (legacy alias for v4-flash think;    deprecated 2026-07-24)
DEEP_THINK_LLM=deepseek-v4-pro
QUICK_THINK_LLM=deepseek-v4-flash
