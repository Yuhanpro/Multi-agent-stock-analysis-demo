# Sample env for production deploy. Copy to .env (in repo root) on the server.

# REQUIRED — your DeepSeek API key from platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxx

# REQUIRED — the URL the user's BROWSER will hit. Used for both:
#   1. CORS allowlist on the FastAPI backend
#   2. NEXT_PUBLIC_API_BASE baked into the frontend bundle
#
# Stage A (IP-only soft-launch):
#   PUBLIC_API_BASE=http://1.2.3.4:18080
# Stage B (after ICP filing):
#   PUBLIC_API_BASE=https://your.domain
PUBLIC_API_BASE=http://1.2.3.4:18080

# Optional overrides (sensible defaults already shipped):
# DAILY_BUDGET_USD=10
# RATE_LIMIT_QUICK=5/hour
# RATE_LIMIT_DEBATE=1/hour
# DEEP_THINK_LLM=deepseek-v4-pro
# QUICK_THINK_LLM=deepseek-v4-flash
