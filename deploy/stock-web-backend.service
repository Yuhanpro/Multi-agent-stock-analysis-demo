[Unit]
Description=stock-web FastAPI backend
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=stockweb
Group=stockweb
EnvironmentFile=/etc/stock-web.env
WorkingDirectory=/home/stockweb/stock-web/backend
# REPO_ROOT is sourced from the env file — but we pin the working dir above
# so the service still works if someone clones to a different path. Just edit
# WorkingDirectory and the PATH below to match.
ExecStart=/usr/local/bin/uv run uvicorn app.main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --workers 1 \
    --log-level info \
    --no-access-log

# Crash handling
Restart=always
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=3

# Resource caps — tune for the server. 2c4g default:
LimitNOFILE=8192
MemoryMax=2G

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/home/stockweb /tmp
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictRealtime=true
RestrictNamespaces=true
LockPersonality=true

[Install]
WantedBy=multi-user.target
