[Unit]
Description=stock-web FastAPI backend
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=stockweb
Group=stockweb
EnvironmentFile=/etc/stock-web.env
WorkingDirectory=/opt/stock-web/backend
ExecStart=/opt/stock-web/backend/.venv/bin/uvicorn app.main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --workers 1 \
    --log-level info \
    --no-access-log

# Crash handling
Restart=always
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=3

# Resource caps — tune for the server. 2c4g default:
LimitNOFILE=8192
MemoryMax=2G

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/stock-web /tmp
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictRealtime=true
RestrictNamespaces=true
LockPersonality=true

[Install]
WantedBy=multi-user.target
